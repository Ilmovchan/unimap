{
  "expo": {
    "name": "UniMap",
    "slug": "unimap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-light.png",
    "scheme": "app",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.illiamovchan.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Дозвіл на камеру для сканування QR-кодів на карті кампусу.",
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/icons/ios-light.png",
        "backgroundImage": "./assets/icons/ios-light.png",
        "monochromeImage": "./assets/icons/ios-light.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.illiamovchan.app",
      "permissions": [
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/ios-light.png"
    },
    "plugins": [
      "./plugins/withIosModulemapFix.js",
      "expo-location",
      [
        "expo-notifications",
        {
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/icons/ios-light.png",
          "dark": {
            "image": "./assets/icons/ios-light.png",
            "backgroundColor": "#FFFFFF"
          },
          "imageWidth": 200
        }
      ],
      "@maplibre/maplibre-react-native",
      "@react-native-community/datetimepicker",
      [
        "expo-camera",
        {
          "cameraPermission": "Дозвіл на камеру для сканування QR-кодів."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "30050548-c68f-4075-b926-919ef86f647a"
      }
    }
  }
}

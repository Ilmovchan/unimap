# Скопіюйте в .env поруч із docker-compose.yml: cp .env.example .env

# Ключі зовнішніх API (опційно)
MAPTILER_API_KEY=
ORS_API_KEY=

# JWT для адмін-панелі (мін. 32 символи)
JWT_SIGNING_KEY=dev-only-change-in-production-min-32-chars!!

# mobile-app (Expo у Docker)
EXPO_PUBLIC_UNIMAP_SERVER_API_LINK=http://localhost:5286/api
# Телефон у Wi‑Fi: IP Mac/PC (для Android dev замість localhost)
# EXPO_PUBLIC_UNIMAP_SERVER_DEV_HOST=192.168.0.108
# Якщо dev client на телефоні не бачить Metro: IP хоста
# REACT_NATIVE_PACKAGER_HOSTNAME=192.168.0.108
